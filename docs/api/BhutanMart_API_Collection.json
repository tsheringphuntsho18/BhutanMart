          "name": "Remove from Cart",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:5000/api/cart/remove/PRODUCT_ID",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE"
              }
            ]
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:5000/api/cart/clear",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE"
              }
            ]
