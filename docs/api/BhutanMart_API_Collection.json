{
  "info": {
    "name": "BhutanMart API",
    "description": "Complete API collection for BhutanMart E-commerce Platform",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/health",
        "header": []
      }
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "http://localhost:5000/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"customer\"\n}"
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": "http://localhost:5000/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/api/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE"
              }
            ]
          }
        },
        {
          "name": "Logout User",
          "request": {
            "method": "POST",
            "url": "http://localhost:5000/api/auth/logout",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/api/categories?page=1&limit=10",
            "header": []
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/api/categories/CATEGORY_ID",
            "header": []
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": "http://localhost:5000/api/categories",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_ADMIN_TOKEN"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic devices and gadgets\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/api/products?page=1&limit=10&sortBy=price_asc",
            "header": []
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/api/products/PRODUCT_ID",
            "header": []
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "http://localhost:5000/api/products",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_SELLER_TOKEN"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wireless Headphones\",\n  \"description\": \"Premium wireless headphones\",\n  \"categoryId\": \"CATEGORY_ID\",\n  \"price\": 99.99,\n  \"stock\": 50,\n  \"tags\": [\"electronics\", \"audio\"],\n  \"variants\": [\n    {\"color\": \"Black\", \"sku\": \"WH-001-BLK\"},\n    {\"color\": \"White\", \"sku\": \"WH-001-WHT\"}\n  ]\n}"
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": "http://localhost:5000/api/products/PRODUCT_ID",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_SELLER_TOKEN"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 89.99,\n  \"stock\": 40\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:5000/api/products/PRODUCT_ID",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_SELLER_TOKEN"
              }
            ]
          }
        }
      ]
    },
