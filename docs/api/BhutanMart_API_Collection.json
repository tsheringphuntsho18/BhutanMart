              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"PRODUCT_ID\",\n      \"name\": \"Product Name\",\n      \"quantity\": 2,\n      \"price\": 99.99\n    }\n  ],\n  \"paymentMethod\": \"COD\"\n}"
