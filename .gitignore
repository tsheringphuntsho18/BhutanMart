# ── Dependencies ─────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Environment files (never commit secrets) ─────────────────
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# ── Build output ─────────────────────────────────────────────
dist/
dist-ssr/
frontend/dist/
build/

# ── Redis persistence files ───────────────────────────────────
dump.rdb
backend/dump.rdb
backend/appendonlydir/

# ── TLS / certificate files ───────────────────────────────────
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx

# ── Test coverage output ──────────────────────────────────────
coverage/
.nyc_output/
backend/coverage/
frontend/coverage/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS / Editor artifacts ────────────────────────────────────
.DS_Store
backend/.DS_Store
frontend/.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local

# ── Uploads (user-uploaded images, not for version control) ───
backend/uploads/*
!backend/uploads/.gitkeep
