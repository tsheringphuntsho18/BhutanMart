# =============================================================
# BhutanMart — Environment Variables Template
# Copy this file to backend/.env and fill in real values.
# Never commit backend/.env or frontend/.env to source control.
# =============================================================

# ── Backend ──────────────────────────────────────────────────

# Server port (default: 5000)
PORT=5000

# MongoDB connection string
# Local replica set:  mongodb://localhost:27017/bhutanmart?replicaSet=rs0
# MongoDB Atlas:      mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/bhutanmart?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/bhutanmart?retryWrites=true&w=majority

# Redis connection URL
# Local:              redis://localhost:6379
# Redis Cloud/Upstash: redis://:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# JWT signing secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ── Frontend ─────────────────────────────────────────────────
# Create frontend/.env and set this variable.
# VITE_API_URL=http://localhost:5000/api
